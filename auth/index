<!DOCTYPE html>
<html>
<head>
    <title>Redirecting...</title>
    <script>
        // خد الكود من URL
        const params = new URLSearchParams(window.location.search);
        const code = params.get("code");

        if (code) {
            // رجّع للتطبيق
            window.location.href = "myapp://auth?code=" + code;
        } else {
            document.body.innerText = "No code found";
        }
    </script>
</head>
<body>
Redirecting...
</body>
</html>
